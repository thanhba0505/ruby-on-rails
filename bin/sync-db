#!/usr/bin/env bash
set -euo pipefail

# ANSI Color Codes
COLOR_RESET="\033[0m"
COLOR_BOLD="\033[1m"
COLOR_RED="\033[31m"
COLOR_GREEN="\033[32m"
COLOR_YELLOW="\033[33m"
COLOR_BLUE="\033[34m"
COLOR_MAGENTA="\033[35m"
COLOR_CYAN="\033[36m"

# Emoji Icons
ICON_CHECK="✅"
ICON_ERROR="❌"
ICON_WARN="⚠️"
ICON_INFO="ℹ️"
ICON_ROCKET="🚀"
ICON_DATABASE="🗄️"
ICON_SYNC="🔄"
ICON_SERVER="🖥️"

# Helper functions for colored output
log_info() {
    echo -e "${COLOR_BOLD}${COLOR_CYAN}${ICON_INFO} $1${COLOR_RESET}"
}

log_success() {
    echo -e "${COLOR_GREEN}${ICON_CHECK} $1${COLOR_RESET}"
}

log_error() {
    echo -e "${COLOR_RED}${ICON_ERROR} $1${COLOR_RESET}"
}

log_warning() {
    echo -e "${COLOR_YELLOW}${ICON_WARN} $1${COLOR_RESET}"
}

log_step() {
    echo -e "${COLOR_BOLD}${COLOR_BLUE}▶ $1${COLOR_RESET}"
}

log_db() {
    echo -e "${COLOR_MAGENTA}${ICON_DATABASE} $1${COLOR_RESET}"
}

# ===== Function to prompt for missing environment variables =====
prompt_for_env() {
  local var_name="$1"
  local default_value="$2"
  local prompt_message="$3"
  local is_secret="$4"  # "true" for passwords, "false" for normal text
  
  # Check if variable is already set
  if [ -n "${!var_name:-}" ]; then
    return 0
  fi
  
  echo ""
  echo "$prompt_message"
  
  if [ -n "$default_value" ]; then
    echo -n "[Default: $default_value]: "
  else
    echo -n ": "
  fi
  
  if [ "$is_secret" = "true" ]; then
    read -r -s user_input
    echo ""
  else
    read -r user_input
  fi
  
  if [ -z "$user_input" ] && [ -n "$default_value" ]; then
    user_input="$default_value"
  fi
  
  if [ -z "$user_input" ]; then
    log_error "$var_name cannot be empty"
  exit 1
fi

# Export the variable
export "$var_name=$user_input"
log_success "$var_name set"
}

# ===== Function to test database connection =====
test_db_connection() {
  local db_type="$1"
  local db_host="$2"
  local db_port="$3"
  local db_name="$4"
  local db_user="$5"
  local db_password="$6"
  
  echo ""
  log_step "Testing $db_type database connection..."
  echo "  Host: $db_host:$db_port"
  echo "  Database: $db_name"
  echo "  User: $db_user"
  
  # Set password for psql
  export PGPASSWORD="$db_password"
  
  # Test connection with a simple query
  if psql -h "$db_host" -p "$db_port" -U "$db_user" -d "$db_name" -c "SELECT 1;" >/dev/null 2>&1; then
    log_success "$db_type database connection successful"
    return 0
  else
    log_error "Failed to connect to $db_type database"
    echo "  Please check your credentials and network connection"
    return 1
  fi
}

# ===== Load existing environment =====
log_info "=== Database Sync Configuration ==="
log_info "Loading environment variables..."

# Try to load .env if exists
if [ -f ".env" ]; then
  log_info "Loading from .env file..."
  # Use a safer way to load .env without affecting current environment
  while IFS='=' read -r key value || [ -n "$key" ]; do
    # Skip comments and empty lines
    [[ $key =~ ^#.* ]] && continue
    [[ -z "$key" ]] && continue
    
    # Remove quotes if present
    value=$(echo "$value" | sed "s/^['\"]//;s/['\"]$//")
    
    # Export variable if not already set
    if [ -z "${!key:-}" ]; then
      export "$key=$value"
    fi
  done < <(grep -v '^#' .env | grep -v '^$')
fi

# ===== Prompt for Production Database Configuration =====
echo ""
log_info "--- Production Database ---"
log_info "Please provide production database credentials:"
prompt_for_env "PRODUCTION_DB_HOST" "" "Production database host (e.g., xxx.xxx.xxx.xxx)" "false"
prompt_for_env "PRODUCTION_DB_PORT" "5432" "Production database port" "false"
prompt_for_env "PRODUCTION_DB_NAME" "" "Production database name" "false"
prompt_for_env "PRODUCTION_DB_USER" "" "Production database username" "false"
prompt_for_env "PRODUCTION_DB_PASSWORD" "" "Production database password" "true"

# ===== Prompt for Local Database Configuration =====
echo ""
log_info "--- Local Database ---"
log_info "Please provide local database credentials (press Enter for defaults):"
prompt_for_env "DB_HOST" "127.0.0.1" "Local database host" "false"
prompt_for_env "DB_PORT" "5432" "Local database port" "false"
prompt_for_env "DB_NAME" "ruby_on_rails_development" "Local database name" "false"
prompt_for_env "DB_USERNAME" "postgres" "Local database username" "false"
prompt_for_env "DB_PASSWORD" "postgres" "Local database password" "true"

# Set local variables from prompted values
LOCAL_DB_HOST="$DB_HOST"
LOCAL_DB_PORT="$DB_PORT"
LOCAL_DB_NAME="$DB_NAME"
LOCAL_DB_USER="$DB_USERNAME"
LOCAL_DB_PASSWORD="$DB_PASSWORD"

log_db "=== Database Connection Testing ==="
log_info "Testing production database connectivity..."

# Test production database connection
if ! test_db_connection "Production" "$PRODUCTION_DB_HOST" "$PRODUCTION_DB_PORT" "$PRODUCTION_DB_NAME" "$PRODUCTION_DB_USER" "$PRODUCTION_DB_PASSWORD"; then
  log_error "Cannot proceed without production database connection"
  exit 1
fi

DUMP_FILE="/tmp/production_$(date +%Y%m%d_%H%M%S).dump"

echo ""
log_info "${COLOR_BOLD}${ICON_SYNC} Database Sync from Production${COLOR_RESET}"
log_db "Production: $PRODUCTION_DB_USER@$PRODUCTION_DB_HOST:$PRODUCTION_DB_PORT/$PRODUCTION_DB_NAME"
log_db "Local: $LOCAL_DB_USER@$LOCAL_DB_HOST:$LOCAL_DB_PORT/$LOCAL_DB_NAME"
echo ""

# Step 1: Dump production database
log_step "1. Dumping production database..."
export PGPASSWORD="$PRODUCTION_DB_PASSWORD"
pg_dump \
  -h "$PRODUCTION_DB_HOST" \
  -p "$PRODUCTION_DB_PORT" \
  -U "$PRODUCTION_DB_USER" \
  -Fc \
  "$PRODUCTION_DB_NAME" \
  -f "$DUMP_FILE"

if [ $? -ne 0 ]; then
  log_error "Failed to dump production database"
  exit 1
fi

log_success "Dump saved to: $DUMP_FILE"
echo "  Size: $(du -h "$DUMP_FILE" | cut -f1)"
echo ""

# Step 2: Drop and recreate local database using PostgreSQL commands
log_step "2. Preparing local database..."
export PGPASSWORD="$LOCAL_DB_PASSWORD"

# First, terminate all active connections to the database
echo "  Terminating active connections to '$LOCAL_DB_NAME'..."
psql \
  -h "$LOCAL_DB_HOST" \
  -p "$LOCAL_DB_PORT" \
  -U "$LOCAL_DB_USER" \
  -d "postgres" \
  -c "SELECT pg_terminate_backend(pid) FROM pg_stat_activity WHERE datname = '$LOCAL_DB_NAME' AND pid <> pg_backend_pid();" \
  2>/dev/null || true

log_info "  Active connections terminated"

# Drop database using dropdb
echo "  Dropping database '$LOCAL_DB_NAME'..."
dropdb \
  -h "$LOCAL_DB_HOST" \
  -p "$LOCAL_DB_PORT" \
  -U "$LOCAL_DB_USER" \
  "$LOCAL_DB_NAME" 2>/dev/null || true

log_success "Database dropped"

# Create database using createdb
echo "  Creating database '$LOCAL_DB_NAME'..."
createdb \
  -h "$LOCAL_DB_HOST" \
  -p "$LOCAL_DB_PORT" \
  -U "$LOCAL_DB_USER" \
  "$LOCAL_DB_NAME"

if [ $? -ne 0 ]; then
  log_error "Failed to create local database"
  rm -f "$DUMP_FILE"
  exit 1
fi

log_success "Database created successfully"
echo ""

# Step 3: Restore to local database
log_step "3. Restoring to local database..."
export PGPASSWORD="$LOCAL_DB_PASSWORD"
pg_restore \
  -h "$LOCAL_DB_HOST" \
  -p "$LOCAL_DB_PORT" \
  -U "$LOCAL_DB_USER" \
  -d "$LOCAL_DB_NAME" \
  --clean \
  --if-exists \
  --no-owner \
  --no-privileges \
  "$DUMP_FILE"

if [ $? -ne 0 ]; then
  log_warning "pg_restore completed with warnings (owner/privilege issues ignored)"
  log_info "  Database content restored, but owner/privilege errors were ignored"
else
  log_success "Database restored successfully"
fi
echo ""

# Step 4: Cleanup
log_step "4. Cleaning up..."
rm -f "$DUMP_FILE"
log_success "Removed dump file: $DUMP_FILE"
echo ""

log_success "${COLOR_BOLD}${ICON_CHECK} Database sync completed successfully!${COLOR_RESET}"
log_db "Local database '$LOCAL_DB_NAME' is now synchronized with production."
echo ""
log_info "${COLOR_BOLD}${ICON_ROCKET} Next steps:${COLOR_RESET}"
log_info "1. Start development server: ${COLOR_GREEN}make dev${COLOR_RESET}"
log_info "2. Check database: ${COLOR_GREEN}bin/rails dbconsole${COLOR_RESET}"